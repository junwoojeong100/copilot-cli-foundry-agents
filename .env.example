# ===== Azure AI Foundry 설정 =====
# Azure AI Foundry 프로젝트 엔드포인트
# 형식: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# 배포된 모델 이름 (예: gpt-4o, gpt-4o-mini)
MODEL_DEPLOYMENT_NAME=gpt-4o

# ===== MCP 서버 (모듈 2) =====
# 02_agent_with_mcp.py는 Azure OpenAI를 직접 호출합니다.
# (Foundry IQ RAG의 hosted MCP는 모듈 3에서 다룹니다)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ===== Foundry IQ (모듈 3) =====
# Azure AI Search 엔드포인트
SEARCH_SERVICE_ENDPOINT=https://your-search-service.search.windows.net

# 지식 베이스 이름
KNOWLEDGE_BASE_NAME=my-knowledge-base

# Foundry 프로젝트 연결 이름 (AI Search 연결)
PROJECT_CONNECTION_NAME=your-search-connection

# ===== Agent Framework (모듈 4) =====
# 모듈 4는 PROJECT_ENDPOINT / MODEL_DEPLOYMENT_NAME만 있으면 동작합니다.
# (OpenAI 직접 사용 시에만 아래를 주석 해제)
# OPENAI_API_KEY=sk-...
